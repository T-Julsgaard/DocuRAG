# Copy this file to .env and fill in your values. Never commit .env.
# ---------------------------------------------------------------------------

# REQUIRED for "Ask" mode. Get a key at https://console.anthropic.com/
# "Search" mode works without any key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Branding (shown in the UI) ---
APP_NAME=DocuRAG
APP_TAGLINE=knowledge base

# --- Model + answer language ---
# See model ids at https://docs.anthropic.com/
ASK_MODEL=claude-haiku-4-5-20251001
ANSWER_LANGUAGE=English

# --- Knowledge base location (optional) ---
# Defaults to the bundled ./knowledge_base. Point this at your own content
# folder to use a different one. Use an absolute path.
# KB_PATH=C:\path\to\your\knowledge_base

# --- Server ---
HOST=127.0.0.1
PORT=3000

# --- Conversation + limits ---
MAX_HISTORY=5
ASK_DAILY_LIMIT=20
ASK_INPUT_TOKEN_LIMIT=200000
ASK_OUTPUT_TOKEN_LIMIT=30000
